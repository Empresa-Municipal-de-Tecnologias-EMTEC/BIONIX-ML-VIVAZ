@{
    Layout = null;
}
<!doctype html>
<html>
<head><meta charset="utf-8"><title>API Demo</title></head>
<body>
    <h1>API Demo — capture from webcam and submit to /api/face/detectjson</h1>
    <video id="video" autoplay playsinline width="480" height="360" style="border:1px solid #ccc"></video>
    <canvas id="canvas" width="480" height="360" style="display:none"></canvas>
    <div>
        <button id="btnCapture">Capture & Detect</button>
    </div>
    <div>
        <h3>Detected rectangle (drawn):</h3>
        <canvas id="outCanvas" width="480" height="360" style="border:1px solid #333"></canvas>
    </div>
    <div>
        <h3>Crop returned by API:</h3>
        <img id="cropImg" />
    </div>

    <script src="/js/demo.js"></script>
</body>
</html>
